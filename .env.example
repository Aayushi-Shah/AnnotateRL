# ── Database ─────────────────────────────────────────────────────────────────
# Docker postgres is configured from these same vars (no duplication).
# DATABASE_URL is auto-assembled from DB_* if not explicitly set.
DB_USER=annotaterl
DB_PASSWORD=annotaterl
DB_NAME=annotaterl
DB_PORT=5433        # use a port != 5432 if local postgres is already running

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Generation ────────────────────────────────────────────────────────────
# Optional — if set, AI auto-generates model responses when tasks are published.
# OpenRouter is preferred (free models available). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...   # legacy, still works if OPENROUTER_API_KEY is not set

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
S3_BUCKET=annotaterl-exports
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# ── Fine-tuning ──────────────────────────────────────────────────────────────
# Closed-loop RLHF: auto-trigger fine-tuning when annotations complete
FINETUNE_ENABLED=true
FINETUNE_PROVIDER=stub          # "stub" simulates training for dev/learning
FINETUNE_MIN_ROWS=1             # minimum training examples to start a job

# ── Frontend ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
